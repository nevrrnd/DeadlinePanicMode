APP_NAME="Deadline Panic Mode"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-backend-domain.com
FRONTEND_URL=https://your-frontend-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=id_ID

LOG_CHANNEL=stack
LOG_LEVEL=debug

# =========================================================================
# DATABASE - Supabase PostgreSQL
# -------------------------------------------------------------------------
# Ambil nilai berikut dari Supabase Dashboard:
#   Project Settings -> Database -> Connection info / Connection string.
# Gunakan koneksi "Session pooler" (port 5432) atau "Transaction pooler"
# (port 6543). Untuk migrate gunakan port 5432.
#
#   DB_HOST     -> host Supabase, contoh: aws-0-ap-southeast-1.pooler.supabase.com
#   DB_PORT     -> 5432 (session) atau 6543 (transaction pooler)
#   DB_DATABASE -> postgres
#   DB_USERNAME -> postgres.<project-ref>   (lihat di dashboard)
#   DB_PASSWORD -> password database yang kamu set saat membuat project
# =========================================================================
DB_CONNECTION=pgsql
DB_HOST=YOUR_SUPABASE_HOST
DB_PORT=5432
DB_DATABASE=postgres
DB_USERNAME=YOUR_SUPABASE_USER
DB_PASSWORD=YOUR_SUPABASE_PASSWORD
DB_SSLMODE=require
DB_SEARCH_PATH=public

# Drivers dibuat tidak bergantung tabel agar setup lebih ringan.
SESSION_DRIVER=file
SESSION_LIFETIME=120
CACHE_STORE=file
QUEUE_CONNECTION=sync

# =========================================================================
# CORS & SANCTUM
# Origin frontend React (Vite). Pisahkan dengan koma jika lebih dari satu.
# =========================================================================
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://your-frontend-domain.com

FILESYSTEM_DISK=local

MAIL_MAILER=log
